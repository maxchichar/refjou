rules_version = '2';

// All reads and writes in this app go through Next.js API routes using the
// Firebase Admin SDK, which bypasses these rules entirely. The client SDK is
// only used here for Authentication (sign up / log in), not for direct
// Firestore access. So: deny all direct client reads/writes by default.
//
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
